#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>

// 1. Credentials
const char* ssid = "******";
const char* password = "*******";
const char* apiKey = "*****";

void setup() {
  Serial.begin(115200);
  delay(1000); 
  
  Serial.println("\nStarting Wi-Fi connection...");
  WiFi.mode(WIFI_STA); 
  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi Connected!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());
  Serial.println("\n--- Type your prompt in the Serial Monitor and press Enter ---");
}

void loop() {
  // Check if there is text waiting in the Serial Monitor
  if (Serial.available() > 0) {
    // Read the incoming string until a newline character
    String userPrompt = Serial.readStringUntil('\n');
    userPrompt.trim(); // Remove any extra spaces or hidden characters

    if (userPrompt.length() > 0) 
    {
      Serial.print("\nUser: ");
      Serial.println(userPrompt);
      Serial.println("Thinking...");
      
      // Send to Groq
      askGroq(userPrompt);
    }
  }
}

void askGroq(String prompt) {
  if (WiFi.status() == WL_CONNECTED) {
    HTTPClient http;

    http.begin("https://api.groq.com/openai/v1/chat/completions");//post url

    //header
    http.addHeader("Content-Type", "application/json");
    http.addHeader("Authorization", "Bearer " + String(apiKey));

    //body
    StaticJsonDocument<768> doc;

    doc["model"] = "llama-3.3-70b-versatile";//version
    doc["max_tokens"] = 60;
    doc["temperature"] = 0.7;

    
    JsonArray messages = doc.createNestedArray("messages");

    //we are trying to edit everthing before hand
    JsonObject msg1 = messages.createNestedObject();
    msg1["role"] = "system";
    msg1["content"] = "your name is jarvis. keep answers short and very funny";

    JsonObject msg3 = messages.createNestedObject();
    msg3["role"] = "user";
    msg3["content"] = prompt;


    //serialization 
    String requestBody;
    serializeJson(doc, requestBody);

    int httpResponseCode = http.POST(requestBody);

    if (httpResponseCode > 0) {
      String response = http.getString();
      
      // Parse the response to get just the text content
      DynamicJsonDocument output(2048);
      DeserializationError error = deserializeJson(output, response);
      
      if (!error) {
        const char* aiResponse = output["choices"][0]["message"]["content"];
        Serial.println("\n--- Groq Response ---");
        Serial.println(aiResponse);
        Serial.println("\n---------------------");
      } else {
        Serial.println("JSON Parsing failed.");
      }
    } else {
      Serial.print("Error on HTTP request: ");
      Serial.println(httpResponseCode);
      // If you get a -1 error, uncomment the line below:
      // http.setInsecure(); 
    }
    http.end();
  } else {
    Serial.println("WiFi Disconnected");
  }
}
